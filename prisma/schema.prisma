datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Gender {
  MALE
  FEMALE
}

enum UserStatus {
  ACTIVE
  FROZEN
  BANNED
}

enum AuditLogType {
  TAB_SWITCH
  FAST_ANSWER
  SUSPICIOUS_IP
  ADMIN_ACTION
}

enum QuestionType {
  RADIO
  TRUE_FALSE
  TEXT
  RANGE
  VOICE
  DRAWING
}

model User {
  id          String     @id @default(uuid()) @db.Uuid
  telegramId  BigInt     @unique
  fullName    String
  phone       String
  age         Int
  gender      Gender
  
  // Demographics
  region      String
  district    String
  mfy         String
  street      String
  house       String

  // Security & State
  status      UserStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  results     Result[]
  auditLogs   AuditLog[]

  // Regional leaderboards / lookups
  @@index([region, district])
}

model Test {
  id          String     @id @default(uuid()) @db.Uuid
  title       String
  subject     String
  description String?    @db.Text
  startDate   DateTime
  endDate     DateTime
  timeLimitMs Int        // Storing as milliseconds for precision

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  questions   Question[]
  results     Result[]

  // Index for querying active tests based on time constraints
  @@index([startDate, endDate])
}

model Question {
  id            String       @id @default(uuid()) @db.Uuid
  testId        String       @db.Uuid
  type          QuestionType @default(RADIO)
  content       String       @db.Text
  mediaUrl      String?      @db.Text
  options       Json         // Array of options, unused or optional for TEXT/VOICE/DRAWING
  correctOption String       // Correct text/range/option ID
  points        Int          @default(1)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  test          Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers       Answer[]

  // Querying questions by their test
  @@index([testId])
}

model Result {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  testId      String   @db.Uuid
  
  score       Int      @default(0)
  timeSpentMs Int      // Time spent in milliseconds for high-resolution tie-breaking
  penaltyPts  Int      @default(0)
  
  completedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)

  // CRITICAL: Composite index for ultra-fast leaderboard fetching
  // B-Tree will sort results by Test ID first, then Score (DESC), then Time (ASC)
  @@index([testId, score(sort: Desc), timeSpentMs(sort: Asc)])
  @@unique([userId, testId]) // Prevents multi-submissions
  
  answers     Answer[]
}

model Answer {
  id            String   @id @default(uuid()) @db.Uuid
  resultId      String   @db.Uuid
  questionId    String   @db.Uuid
  value         String   @db.Text // Can be option ID, text, or URL to voice/drawing
  isCorrect     Boolean?
  pointsAwarded Int?

  createdAt     DateTime @default(now())

  result        Result   @relation(fields: [resultId], references: [id], onDelete: Cascade)
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([resultId, questionId])
  @@index([resultId])
}

model AuditLog {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @db.Uuid
  type        AuditLogType
  description String       @db.Text
  metadata    Json?        // Additional tracking data (e.g., {"browser": "...", "tabSwitchedAt": 1690000000})
  
  createdAt   DateTime     @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // For quick user timeline generation and threat detection
  @@index([userId, createdAt(sort: Desc)])
  @@index([type])
}
